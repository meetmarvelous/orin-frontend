{
  "license": "ISC",
  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "rpc": "solana-test-validator",
    "build": "anchor build",
    "deploy_devnet": "anchor build && anchor deploy --provider.cluster devnet",
    "deploy_local": "anchor build && anchor deploy --provider.cluster localnet",
    "start": "cd backend && ts-node src/listener.ts",
    "simulate": "cd backend && ts-node src/simulate_frontend.ts",
    "start_devnet": "cd backend && export NETWORK=Devnet && ts-node src/listener.ts",
    "simulate_devnet": "cd backend && export NETWORK=Devnet && ts-node src/simulate_frontend.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1"
  },
  "devDependencies": {
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "ts-mocha": "^10.0.0",
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "typescript": "^5.7.3",
    "prettier": "^2.6.2"
  }
}
