{
    "name": "backend",
    "version": "1.0.0",
    "main": "index.js",
    "license": "MIT",
    "description": "",
    "scripts": {
        "build": "tsc",
        "start:listener": "ts-node src/listener.ts",
        "start:api": "ts-node src/api/server.ts",
        "start:listener:prod": "node dist/listener.js",
        "start:api:prod": "node dist/api/server.js",
        "prod:all": "concurrently -k -n api,listener \"npm run start:api:prod\" \"npm run start:listener:prod\"",
        "validate:env": "ts-node src/config/validate_env.ts",
        "dev:all": "npm run validate:env && concurrently -k -n api,listener \"npm run start:api\" \"npm run start:listener\"",
        "simulate": "ts-node src/simulate_frontend.ts",
        "simulate:duffel": "ts-node src/simulate_frontend.ts --duffel",
        "start_devnet": "set NETWORK=devnet&& ts-node src/listener.ts",
        "simulate_devnet": "set NETWORK=devnet&& ts-node src/simulate_frontend.ts",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "keywords": [],
    "author": "",
    "type": "commonjs",
    "dependencies": {
        "@coral-xyz/anchor": "^0.32.1",
        "@deepgram/sdk": "^3.13.0",
        "@fastify/cors": "^11.2.0",
        "@fastify/multipart": "^9.4.0",
        "@fastify/static": "^9.1.3",
        "@fastify/websocket": "^11.2.0",
        "@langchain/core": "^1.1.36",
        "@solana/spl-token": "^0.4.14",
        "@solana/web3.js": "^1.98.4",
        "bs58": "^6.0.0",
        "concurrently": "^9.2.1",
        "dotenv": "^17.3.1",
        "fastify": "^5.8.4",
        "firebase-admin": "^13.7.0",
        "ioredis": "^5.10.1",
        "mqtt": "^5.15.0",
        "pino": "^10.3.1",
        "uuid": "^13.0.0",
        "ws": "^8.20.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    }
}
